services:
  rabbitmq:
    image: rabbitmq:3.12-management-alpine
    container_name: codegen-rabbitmq
    ports:
      - "5672:5672"
      - "15672:15672"
    environment:
      RABBITMQ_DEFAULT_USER: codegen
      RABBITMQ_DEFAULT_PASS: ${RABBITMQ_PASSWORD}
    volumes:
      - rabbitmq_data:/var/lib/rabbitmq
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - codegen-net

  redis:
    image: redis:7-alpine
    container_name: codegen-redis
    ports:
      - "6379:6379"
    command: redis-server --appendonly yes --requirepass ${REDIS_PASSWORD}
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "-a", "${REDIS_PASSWORD}", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - codegen-net

  coordinator:
    build:
      context: ./coordinator
      dockerfile: Dockerfile
    container_name: codegen-coordinator
    ports:
      - "8000:8000"
    environment:
      - RABBITMQ_URL=amqp://codegen:${RABBITMQ_PASSWORD}@rabbitmq:5672/
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
      - OLLAMA_HOST=http://host.docker.internal:11434
    depends_on:
      rabbitmq:
        condition: service_healthy
      redis:
        condition: service_healthy
    volumes:
      - ./logs:/app/logs
    networks:
      - codegen-net
    restart: unless-stopped

  # NEW: Prompt Analyzer Agent
  agent-analyzer:
    build:
      context: ./agents/analyzer
      dockerfile: Dockerfile
    container_name: codegen-agent-analyzer
    environment:
      - RABBITMQ_URL=amqp://codegen:${RABBITMQ_PASSWORD}@rabbitmq:5672/
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
      - OLLAMA_HOST=http://host.docker.internal:11434
      - MODEL_NAME=deepseek-coder:6.7b-instruct-q4_K_M
    depends_on:
      - rabbitmq
      - redis
    volumes:
      - ./logs:/app/logs
    networks:
      - codegen-net
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1024M

  agent-writer:
    build:
      context: ./agents/writer
      dockerfile: Dockerfile
    container_name: codegen-agent-writer
    environment:
      - RABBITMQ_URL=amqp://codegen:${RABBITMQ_PASSWORD}@rabbitmq:5672/
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
      - OLLAMA_HOST=http://host.docker.internal:11434
      - MODEL_NAME=deepseek-coder:6.7b-instruct-q4_K_M
    depends_on:
      - rabbitmq
      - redis
    volumes:
      - ./logs:/app/logs
    networks:
      - codegen-net
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '2.0'
          memory: 1536M

  agent-verifier:
    build:
      context: ./agents/verifier
      dockerfile: Dockerfile
    container_name: codegen-agent-verifier
    environment:
      - RABBITMQ_URL=amqp://codegen:${RABBITMQ_PASSWORD}@rabbitmq:5672/
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
      - OLLAMA_HOST=http://host.docker.internal:11434
      - MODEL_NAME=deepseek-coder:6.7b-instruct-q4_K_M
    depends_on:
      - rabbitmq
      - redis
    volumes:
      - ./logs:/app/logs
    networks:
      - codegen-net
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1024M

  agent-tester:
    build:
      context: ./agents/tester
      dockerfile: Dockerfile
    container_name: codegen-agent-tester
    environment:
      - RABBITMQ_URL=amqp://codegen:${RABBITMQ_PASSWORD}@rabbitmq:5672/
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
      - OLLAMA_HOST=http://host.docker.internal:11434
      - MODEL_NAME=deepseek-coder:6.7b-instruct-q4_K_M
    depends_on:
      - rabbitmq
      - redis
    volumes:
      - ./logs:/app/logs
    networks:
      - codegen-net
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.5'
          memory: 1536M

  agent-improver:
    build:
      context: ./agents/improver
      dockerfile: Dockerfile
    container_name: codegen-agent-improver
    environment:
      - RABBITMQ_URL=amqp://codegen:${RABBITMQ_PASSWORD}@rabbitmq:5672/
      - REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
      - OLLAMA_HOST=http://host.docker.internal:11434
      - MODEL_NAME=deepseek-coder:6.7b-instruct-q4_K_M
    depends_on:
      - rabbitmq
      - redis
    volumes:
      - ./logs:/app/logs
    networks:
      - codegen-net
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 1024M

volumes:
  rabbitmq_data:
    driver: local
  redis_data:
    driver: local

networks:
  codegen-net:
    driver: bridge